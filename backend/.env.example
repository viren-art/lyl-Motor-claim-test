# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roojai_claims
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL_CA=/path/to/rds-ca-cert.pem

# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=roojai-claims-documents

# Security
PII_ENCRYPTION_KEY=generate_with_crypto_randomBytes_32_hex
ALLOWED_ORIGINS=https://roojai.com,https://app.roojai.com

# Feature Flags
ENABLE_PHOTO_VALIDATION=true
ENABLE_PDPA_LOGGING=true

# LLM Service
LLM_SERVICE_URL=http://localhost:8001