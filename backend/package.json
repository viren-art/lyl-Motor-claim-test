{
  "name": "roojai-claims-backend",
  "version": "1.0.0",
  "description": "Roojai Motor Claims FNOL & Triage Copilot Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:accuracy": "jest --testPathPattern=accuracy-validation --verbose",
    "lint": "eslint src/ tests/",
    "migrate": "node src/database/migrate.js"
  },
  "keywords": [
    "insurance",
    "claims",
    "llm",
    "thai"
  ],
  "author": "Roojai",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/database/migrate.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}